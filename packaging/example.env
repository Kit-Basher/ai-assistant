# Example environment file for personal-agent
# Copy this file to /etc/personal-agent/<username>.env and replace placeholders.
# NEVER commit real tokens into the repository.

# REQUIRED: Telegram bot token
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"

# OPTIONAL: timezone for the agent (default: UTC)
# AGENT_TIMEZONE="UTC"

# OPTIONAL: path to sqlite DB (defaults to /home/<user>/personal-agent/memory/agent.db)
# DB_PATH="/home/<user>/personal-agent/memory/agent.db"

# OPTIONAL: path to log file
# LOG_PATH="/home/<user>/personal-agent/logs/personal-agent.log"